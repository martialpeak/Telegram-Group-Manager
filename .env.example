# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Bot language: fa | en
BOT_LANG=fa

# Admin user IDs (numeric, comma-separated)
ADMIN_IDS=123456789,987654321

# AI Provider: groq | gemini
AI_PROVIDER=groq

# Groq (primary, 14400 req/day free) - https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (fallback, 1500 req/day free) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Group management
MAX_WARNINGS=3
SPAM_TIME_WINDOW=60
SPAM_MAX_MESSAGES=5
MIN_CONFIDENCE=0.80

# Cache
CACHE_MIN_SCORE=0.75
CACHE_TTL_HOURS=24

# Learning
LEARNING_ENABLED=true
LEARNING_BATCH_SIZE=50
LEARNING_MIN_SCORE=0.75
SEARCH_TOP_K=5

# Training channels (source for bot learning)
# Comma-separated. Bot reads these via t.me/s/ (no API needed, public channels only)
# Example: TRAINING_CHANNELS=@my_tech_channel,@vpn_help
TRAINING_CHANNELS=

# Web search fallback (when AI has no answer)
# true = enabled | false = disabled
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=3

# Minimum AI response delay (seconds) - for better loading UX
AI_MIN_RESPONSE_DELAY=4

# ── تلگرام ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── زبان ربات ─────────────────────────────────────────
# fa = فارسی | en = English
BOT_LANG=fa

# ── ادمین‌ها (شناسه عددی، با کاما جدا) ───────────────
ADMIN_IDS=123456789,987654321

# ── AI Provider ───────────────────────────────────────
# primary: groq | gemini
AI_PROVIDER=groq

# Groq (primary — 14400 req/day free)
# https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Gemini (fallback — 1500 req/day free)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── مدیریت گروه ──────────────────────────────────────
MAX_WARNINGS=3
SPAM_TIME_WINDOW=60
SPAM_MAX_MESSAGES=5
MIN_CONFIDENCE=0.80

# ── Cache ─────────────────────────────────────────────
CACHE_MIN_SCORE=0.75
CACHE_TTL_HOURS=24

# ── یادگیری ──────────────────────────────────────────
LEARNING_ENABLED=true
LEARNING_BATCH_SIZE=50
LEARNING_MIN_SCORE=0.75
SEARCH_TOP_K=5

# ── کانال‌های آموزشی (منبع یادگیری ربات) ─────────────────
# با کاما جدا شود. ربات باید عضو این کانال‌ها باشد.
# مثال: TRAINING_CHANNELS=@my_tech_channel,@vpn_help
TRAINING_CHANNELS=

# ── سرچ در وب (وقتی AI جواب نمی‌داند) ────────────────────
# true = فعال | false = غیرفعال
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=3

# ── تاخیر حداقل پاسخ AI (ثانیه) ──────────────────────────
# برای نمایش بهتر لودینگ و افزایش دقت
AI_MIN_RESPONSE_DELAY=4

# ── Telethon (برای خواندن تاریخچه کانال‌ها) ────────────────
# از https://my.telegram.org/apps بگیر (رایگان)
# می‌تونی خالی بذاری — فقط /sync کار نمی‌کنه، بقیه چیزها درسته
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
